meta {
  name: Protected - Wrong Token
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/protected
  body: none
  auth: bearer
}

auth:bearer {
  token: invalidtoken
}

assert {
  res.status: eq 401
  res.body.success: eq false
}

tests {
  test("returns 401 Unauthorized with a wrong token", function () {
    expect(res.getStatus()).to.equal(401);
    expect(res.getBody().error).to.equal("Unauthorized");
  });
}
