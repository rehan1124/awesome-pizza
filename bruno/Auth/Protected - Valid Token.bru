meta {
  name: Protected - Valid Token
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/protected
  body: none
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

assert {
  res.status: eq 200
  res.body.success: eq true
}

tests {
  test("returns 200 OK with a valid token", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().success).to.equal(true);
    expect(res.getBody().message).to.include("Access granted");
  });
}
