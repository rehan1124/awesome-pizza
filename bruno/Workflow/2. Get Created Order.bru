meta {
  name: 2. Get Created Order
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/orders/{{orderId}}
  body: none
  auth: none
}

headers {
  Accept: application/json
}

assert {
  res.status: eq 200
}

tests {
  test("fetches the order created in step 1", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().data.id).to.equal(bru.getVar("orderId"));
    expect(res.getBody().data.status).to.equal("RECEIVED");
  });
}
