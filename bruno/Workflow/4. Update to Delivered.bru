meta {
  name: 4. Update to Delivered
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/api/orders/{{orderId}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "status": "DELIVERED"
  }
}

assert {
  res.status: eq 200
  res.body.data.status: eq DELIVERED
}

tests {
  test("order is delivered", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().data.status).to.equal("DELIVERED");
  });
}
